# AWS Region
aws_region = "us-east-1"

# Project Name (used for resource tagging)
project_name = "techchallenge1-fiap"

# EC2 Instance Type
ec2_instance_type = "t3.micro"

# Key Pair Name (must exist in AWS)
key_pair_name = "keypair-techchallenge1-fiap"

# Allowed IP for SSH access (IMPORTANT: Change to your IP for security)
# Get your IP: curl -s https://checkip.amazonaws.com
# Format: "YOUR_IP/32" for single IP or "0.0.0.0/0" for any IP (not recommended)
allowed_ssh_ip = "0.0.0.0/0"  # CHANGE THIS!

# RDS Database Configuration
db_username = "dbadmin"
db_password = "fiaptech34233!"
db_name     = "togglemaster"

# VPC CIDR
vpc_cidr = "10.0.0.0/16"
